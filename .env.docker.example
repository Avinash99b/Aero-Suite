# Env vars for docker-compose.yml / standalone Docker deployment of SkyReserve.
# Copy to .env.docker and fill in real values; never commit the filled-in file.

# --- Backend (api-server) ---
DATABASE_URL=postgres://user:password@host:5432/skyreserve
CLERK_SECRET_KEY=sk_live_or_test_xxx
CLERK_PUBLISHABLE_KEY=pk_live_or_test_xxx
SESSION_SECRET=
CORS_ORIGIN=*
LOG_LEVEL=info
API_PORT=8080

# --- Frontend (web) ---
# Absolute URL the browser should call for the API; leave as-is if running
# both services via this compose file on the same host.
API_BASE_URL=http://localhost:8080
CLERK_PROXY_URL=
WEB_PORT=8081
